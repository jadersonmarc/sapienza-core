# Postgres (um só — control plane em public, schemas de tenant tenant_<id>)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sapienza

# NextAuth (sessão JWT stateless)
AUTH_SECRET=troque-por-openssl-rand-base64-32
# Necessário fora do Vercel (Coolify): base URL pública do console
AUTH_TRUST_HOST=true

# Segredo dos JWT curtos emitidos aos produtos (validado pelo sapienza-kit/authclient).
# Precisa ser o MESMO valor no core, no margot e no motor.
PRODUCT_JWT_SECRET=troque-por-um-segredo-forte

# Secret dos jobs agendados (POST /api/cron/billing-close). Sem ele o endpoint
# nega tudo (fail-closed) e o fechamento mensal nunca roda.
WEBHOOK_SECRET=

# Base URL da API do Margot (data plane multi-tenant; o console fala via BFF com JWT).
MARGOT_API_URL=http://localhost:8081

# Base URL da API do Motor (data plane de conteúdo; o console fala via BFF com JWT).
MOTOR_API_URL=http://localhost:3100

# AES-256-GCM p/ segredos por-tenant (32 bytes base64): openssl rand -base64 32
AGENT_TOKEN_ENC_KEY=

# Pagamentos (Asaas). Sem estes, as faturas são calculadas mas não geram cobrança.
# Sandbox por padrão; chaves e URL são DISTINTAS entre sandbox e produção.
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
ASAAS_API_KEY=
# Token que o Asaas envia no header `asaas-access-token` do webhook (você define no
# painel do Asaas e repete aqui). Sem ele, /api/webhooks/asaas recusa tudo.
ASAAS_WEBHOOK_TOKEN=

# Checkout self-service do site (spa-sapienza). Segredo do header `x-checkout-secret`
# que só o site conhece, autorizando /api/public/checkout (server-to-server). MESMO
# valor dos dois lados. Sem ele, a rota recusa tudo (401). Gerar: openssl rand -base64 32
CHECKOUT_SECRET=
